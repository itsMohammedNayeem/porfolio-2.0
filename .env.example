# All values below are PUBLIC identifiers (safe to commit) and OPTIONAL —
# the code falls back to these exact values when unset.
# Copy to .env.local to override (e.g. a different dataset for testing).

NEXT_PUBLIC_SANITY_PROJECT_ID="79vh6zyc"
NEXT_PUBLIC_SANITY_DATASET="production"

# NEXT_PUBLIC_BASE_URL is no longer used: the app queries Sanity directly
# instead of round-tripping through its own /api routes.
